# Copy this file to .env and fill real values

# AI keys
KILO_API_KEY=
GEMINI_API_KEY=
GROQ_API_KEY=

# Server
PORT=5000

# Security
JWT_SECRET=replace_with_a_strong_secret
COOKIE_SECURE=false
FRONTEND_ORIGINS=http://localhost:5173

# Main admin bootstrap (stored in teachers table as hashed password)
ADMIN_USERNAME=Main Admin
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change_this_admin_password

# Database
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=
DB_NAME=exam_portal_v2
DB_POOL_SIZE=20
