# Copy this file to .env and fill real values

# AI keys
KILO_API_KEY=
GEMINI_API_KEY=
GROQ_API_KEY=
K2THINK_API_KEY=
K2_API_KEY=

# Optional K2 Think settings
K2THINK_MODEL=MBZUAI-IFM/K2-Think-v2
K2THINK_API_URL=https://api.k2think.ai/v1/chat/completions

# Optional default provider: auto | groq | gemini | k2
AI_DEFAULT_PROVIDER=auto

# Server
PORT=5000

# Security
JWT_SECRET=replace_with_a_strong_secret
COOKIE_SECURE=false
FRONTEND_ORIGINS=http://localhost:5173

# Main admin bootstrap (stored in teachers table as hashed password)
ADMIN_USERNAME=Main Admin
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change_this_admin_password

# Database
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=
DB_NAME=exam_portal_v2
DB_POOL_SIZE=20
